<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 就绪：默认只显示未通过项 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="就绪检测"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/toggleChecksButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="展开全部"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/readinessSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="检测中…"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/checklistContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/checksEmptyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="全部通过 ✓"
            android:textSize="13sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/setupWizardButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="打开设置向导" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:background="#33000000" />

        <!-- 连接 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="连接 MeoBrowser"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/pair_hint"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="配对码（6 位）">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/pairingCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="6" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="手动主机（IP:端口）">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/hostOverrideInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="例如 192.168.1.10:12345"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="连接 / 配对" />

        <Button
            android:id="@+id/disconnectButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="断开" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="状态：未连接"
            android:textSize="15sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:background="#33000000" />

        <!-- 最近验证码：醒目 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="最近验证码"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lastOtpCodeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#14000000"
            android:gravity="center"
            android:letterSpacing="0.12"
            android:padding="16dp"
            android:text="——"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lastOtpMetaText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="等待短信 / 通知验证码"
            android:textSize="13sp" />

        <Button
            android:id="@+id/rescanNotifButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="从通知栏重新读取并推送" />

        <Button
            android:id="@+id/notifAccessButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="开启通知使用权（小米必开）" />

        <TextView
            android:id="@+id/notifAccessHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="小米服务号短信需通知使用权才能自动抓码。"
            android:textSize="12sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:background="#33000000" />

        <!-- 测试区 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="测试区"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="仅用于排查权限与连接，日常登录不必使用。"
            android:textSize="12sp" />

        <Button
            android:id="@+id/readRecentOtpButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="读取最近验证码短信" />

        <TextView
            android:id="@+id/recentOtpResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="从系统短信库主动扫描（小米服务号常读不到）。"
            android:textSize="12sp" />

        <Button
            android:id="@+id/manualOtpButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="手动发送测试码" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/privacy_note"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
