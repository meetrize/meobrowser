<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="8dp"
    android:background="#FFFFFFFF">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="#FFD1D5DB" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp"
        android:text="@string/tools_panel"
        android:textColor="#FF1C1C1E"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/toolsDownloads"
        style="@style/ToolsSheetRow"
        android:text="@string/tools_downloads" />

    <TextView
        android:id="@+id/toolsNewBookmark"
        style="@style/ToolsSheetRow"
        android:text="@string/tools_new_bookmark" />

    <TextView
        android:id="@+id/toolsDesktopMode"
        style="@style/ToolsSheetRow"
        android:text="@string/tools_desktop_mode" />

    <TextView
        android:id="@+id/toolsReload"
        style="@style/ToolsSheetRow"
        android:text="@string/tools_reload" />

    <TextView
        android:id="@+id/toolsFullscreen"
        style="@style/ToolsSheetRow"
        android:text="@string/tools_fullscreen" />

    <TextView
        android:id="@+id/toolsRotate"
        style="@style/ToolsSheetRow"
        android:text="@string/tools_rotate" />

    <TextView
        android:id="@+id/toolsFontSize"
        style="@style/ToolsSheetRow"
        android:text="@string/tools_font_size" />

    <TextView
        android:id="@+id/toolsCollapse"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="@string/tools_collapse"
        android:textColor="#FF007AFF"
        android:textSize="15sp"
        android:background="?attr/selectableItemBackground" />
</LinearLayout>
