<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/shortcut_field_title"
            android:textColor="#FF6B7280"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/shortcutTitleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/shortcut_hint_title"
            android:inputType="text"
            android:maxLines="1"
            android:importantForAutofill="no" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/shortcut_field_url"
            android:textColor="#FF6B7280"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/shortcutUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/shortcut_hint_url"
            android:inputType="textUri"
            android:maxLines="1"
            android:importantForAutofill="no" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/shortcut_field_icon"
            android:textColor="#FF6B7280"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_shortcut_icon_white"
                android:elevation="2dp">

                <ImageView
                    android:id="@+id/shortcutIconPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:padding="6dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/shortcutIconLetter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#FF6B7280"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <EditText
                android:id="@+id/shortcutIconUrlInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:hint="@string/shortcut_hint_icon"
                android:inputType="textUri"
                android:maxLines="1"
                android:importantForAutofill="no" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/shortcutFetchIconButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="@string/shortcut_fetch_icon"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/shortcutEditError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFF3B30"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
