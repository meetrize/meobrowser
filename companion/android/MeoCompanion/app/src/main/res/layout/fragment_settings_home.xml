<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_general"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/generalSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/settings_general_hint"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#33000000" />

        <TextView
            android:id="@+id/openLinkSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="12dp"
            android:text="@string/settings_section_link"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/openNotificationSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="12dp"
            android:text="@string/settings_section_notification"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/openSyncSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="12dp"
            android:text="@string/settings_section_sync"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/openDownloadSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="12dp"
            android:text="@string/settings_section_downloads"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/openHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="12dp"
            android:text="@string/settings_section_history"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/openBookmarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="12dp"
            android:text="@string/settings_section_bookmarks"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#33000000" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_about"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_about_body"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
